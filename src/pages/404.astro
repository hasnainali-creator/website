---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/base.astro";

const entry = await getEntry("views", "error404");

if (!entry) {
  throw new Error("404 page not found");
}

---

<BaseLayout entry={entry}>
  <div class="container flex flex-col items-center justify-center py-20">
    <h1 class="text-4xl text-center">{entry.data.title || "404 - Page Not Found"}</h1>
    <p class="mt-2 text-center">{entry.data.description || "The page you are looking for does not exist."}</p>
    <a href="/" class="btn mt-6 font-semibold" aria-label="Return to Homepage"
      >Return to Homepage</a
    >
  </div>
</BaseLayout>
