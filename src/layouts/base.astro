---
import "../styles/global.css";
import { SITE } from "@/lib/config";
import Head from "@/components/bases/head.astro";
import Header from "@/components/shared/header.astro";
import Footer from "@/components/shared/footer.astro";
import NotificationManager from "@/components/shared/NotificationManager.astro";
import type { Entry, Meta, ArticleMeta } from "@/lib/types";
import { getMeta } from "@/lib/utils/getMeta";

type Props = {
  entry?: Entry;
  meta?: Meta | ArticleMeta;
  preloadImage?: string | any;
  preloadSizes?: string;
};

const { entry, meta: metaProp, preloadImage, preloadSizes = "100vw" } = Astro.props;

const meta = metaProp || (entry ? await getMeta(entry) : undefined);

if (!meta) {
  throw new Error("BaseLayout requires either an entry or a meta prop.");
}
---

<!doctype html>
<html lang={SITE.locale} dir={SITE.dir}>
  <Head meta={meta} preloadImage={preloadImage} preloadSizes={preloadSizes} />
  <body class="flex flex-col">
    <style is:inline>
      #brand-splash {
        display: none; /* Hidden by default for website visitors */
      }
      
      /* ONLY show the splash screen when launched as a standalone App */
      @media (display-mode: standalone), (display-mode: fullscreen), (display-mode: minimal-ui) {
        #brand-splash {
          position: fixed;
          top: 0; left: 0;
          width: 100%; height: 100%;
          background: #0a0a0a;
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 99999;
          transition: opacity 0.4s ease-in-out, visibility 0.4s;
        }
      }

      #brand-splash.hide { opacity: 0; visibility: hidden; }
      .splash-logo {
        width: 80px; height: 80px;
        fill: #ffffff;
      }
    </style>
    <div id="brand-splash">
      <svg class="splash-logo" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.672 15.226l-2.432.811.841 2.515c.33 1.019-.209 2.127-1.23 2.456-1.15.325-2.148-.321-2.463-1.226l-.84-2.518-5.013 1.677.84 2.517c.391 1.203-.434 2.542-1.831 2.542-.88 0-1.601-.564-1.86-1.314l-.842-2.516-2.431.809c-1.135.328-2.145-.317-2.463-1.229-.329-1.018.211-2.127 1.231-2.456l2.432-.809-1.621-4.823-2.432.808c-1.355.384-2.558-.59-2.558-1.839 0-.817.509-1.582 1.327-1.846l2.433-.809-.842-2.515c-.33-1.02.211-2.129 1.232-2.458 1.02-.329 2.13.209 2.461 1.229l.842 2.515 5.011-1.677-.839-2.517c-.403-1.238.484-2.553 1.843-2.553.819 0 1.585.509 1.85 1.326l.841 2.517 2.431-.81c1.02-.33 2.131.211 2.461 1.229.332 1.018-.21 2.126-1.23 2.456l-2.433.809 1.622 4.823 2.433-.809c1.242-.401 2.557.484 2.557 1.838 0 .819-.51 1.583-1.328 1.847m-8.992-6.428l-5.01 1.675 1.619 4.828 5.011-1.674-1.62-4.829z"/>
      </svg>
    </div>
    <script is:inline>
      // Professional Splash Handler - Only for PWA launch
      if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone) {
        window.addEventListener('load', () => {
          const splash = document.getElementById('brand-splash');
          setTimeout(() => {
            splash.classList.add('hide');
          }, 300);
        });
      }
    </script>

    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script src="/z-engine.js" defer is:inline></script>
    <NotificationManager />
  </body>
</html>
