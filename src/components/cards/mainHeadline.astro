---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import Divider from "@/components/bases/divider.astro";
import { categoriesHandler, normalizeCategoryData } from "@/lib/handlers/categories";
import { getDateDistance } from "@/lib/utils/date";
import { getImage } from "astro:assets";

const catProvider = await categoriesHandler.getProvider();

type Props = {
  article: CollectionEntry<"articles">;
};

const { article } = Astro.props;

// Zenith High-Performance Execution: Manual AVIF Generation for Universal Speed
const q = 35; // Exact match with head.astro for absolute cache hit
const img400 = await getImage({ src: article.data.cover, format: 'avif', width: 400, quality: q });
const img665 = await getImage({ src: article.data.cover, format: 'avif', width: 665, quality: q });
const img800 = await getImage({ src: article.data.cover, format: 'avif', width: 800, quality: q });
const img1024 = await getImage({ src: article.data.cover, format: 'avif', width: 1024, quality: q });
const lcpSrcset = `${img400.src} 400w, ${img665.src} 665w, ${img800.src} 800w, ${img1024.src} 1024w`;

const { remarkPluginFrontmatter } = await render(article);
---

<article class="group relative isolate flex flex-col-reverse md:flex-col gap-4">
  <div class="overflow-hidden rounded-md relative" style="aspect-ratio: 16 / 9; width: 100%;">
    <img
      src={img800.src}
      srcset={lcpSrcset}
      alt={article.data.coverAlt || article.data.title || "Main Headline News"}
      sizes="(max-width: 768px) calc(100vw - 32px), 800px"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
      class="aspect-video rounded-md w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      width="1366"
      height="768"
    />
  </div>
  <div class="flex flex-col gap-2">
    <div>
      <h2
        class="text-xl font-semibold lg:group-hover:underline underline-offset-2"
      >
        <a href={`/articles/${article.id}`}>
          <span class="absolute inset-0 z-10"></span>
          {article.data.title}
        </a>
      </h2>
      <p class="text-base-content/90 text-base max-w-lg">
        {article.data.description}
      </p>
    </div>
    <div class="flex items-center text-xs text-base-content/80 mt-2">
      <span class="text-primary dark:text-secondary"
        >{catProvider.getDisplayPath(normalizeCategoryData(article.data.category)[0]?.discriminant || "uncategorized")}</span
      >
      <Divider />
      <span>{getDateDistance(remarkPluginFrontmatter.lastModified)}</span>
    </div>
  </div>
</article>
