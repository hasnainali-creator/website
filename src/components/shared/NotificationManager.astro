---
// NotificationManager.astro
// Best Practice: Never request notification permission on page load.
// is:inline prevents Astro from bundling it into the critical JS chain.
---
<script is:inline>
  (function() {
    // Only proceed if permissions are already given
    if (!('Notification' in window) || Notification.permission !== 'granted') return;

    // Load Firebase logic only if necessary, completely non-blocking
    function loadNotifs() {
      // Defer execution by 3 seconds so it's far from FCP/LCP
      setTimeout(() => {
        const script = document.createElement('script');
        script.src = '/notif-manager-init.js'; // Put the heavy firebase logic here or lazy load
        script.async = true;
        document.body.appendChild(script);
      }, 3000);
    }

    if (document.readyState === 'complete') {
        loadNotifs();
    } else {
        window.addEventListener('load', loadNotifs);
    }
  })();
</script>
