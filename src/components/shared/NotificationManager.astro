---
// NotificationManager.astro
// Ultimate Hard Intelligence Push Logic
---
<script is:inline>
  // @ts-nocheck
  (function() {
    // 1. Core State
    if (!('Notification' in window)) return;
    
    // Always load subscriber silently if permission was previously ALREADY GRANTED.
    if (Notification.permission === 'granted') {
      const s = document.createElement('script');
      s.src = '/notif-manager-init.js';
      s.async = true;
      document.body.appendChild(s);
      return; 
    }

    // If denied, stop everything. We cannot prompt.
    if (Notification.permission === 'denied') return;

    // At this point, permission is strictly 'default'.
    
    // We use sessionStorage so click count persists across page navigations in this tab.
    let clickCount = parseInt(sessionStorage.getItem('notif_clicks') || '0', 10);
    let timerFired = false;

    const finalize = (permission) => {
      if (permission === 'granted') {
        const s = document.createElement('script');
        s.src = '/notif-manager-init.js';
        s.async = true;
        document.body.appendChild(s);
      }
    };

    // 12-Second Native Idle Timer
    const idleTimer = setTimeout(() => {
      if (Notification.permission !== 'default') return;
      timerFired = true;
      // Note: Chrome may block this without a user gesture, but Safari/Firefox might allow it.
      // This is purely Native Notification Popup. No "Fake HTML" popup.
      Notification.requestPermission().then(finalize).catch(e => console.error("Auto prompt blocked:", e));
    }, 12000);

    // The Master Trigger Function for Clicks
    const triggerNativePrompt = (event) => {
      if (Notification.permission !== 'default') return;

      const link = event.target ? event.target.closest('a') : null;
      const isInternalLink = link && link.href && !link.href.startsWith('javascript') && link.target !== '_blank';
      
      if (isInternalLink) {
        // MAQSAD PURA: Pause navigation, native prompt, then seamlessly navigate
        event.preventDefault();
        event.stopPropagation();
        
        Notification.requestPermission().then(p => {
          finalize(p);
          window.location.href = link.href;
        }).catch(() => {
          window.location.href = link.href;
        });
        
        // Failsafe timer if the permission promise hangs
        setTimeout(() => { if (window.location.href !== link.href) window.location.href = link.href; }, 400);
      } else {
        // Simple Interaction (e.g. clicking empty space or non-link elements)
        Notification.requestPermission().then(finalize).catch(e => console.error(e));
      }
    };

    // Global Click Interceptor (Catches EVERY possible click on the website)
    document.addEventListener('click', (e) => {
      if (Notification.permission !== 'default') return;
      
      clickCount++;
      sessionStorage.setItem('notif_clicks', clickCount.toString());
      
      // Clear the idle timer since they interacted with the site
      clearTimeout(idleTimer);

      // Psychology Matrix:
      // Click 1: 50% Chance
      // Click 2+: 100% Chance
      const coinToss = Math.random();
      const shouldTrigger = (clickCount === 1 && coinToss > 0.5) || (clickCount >= 2);

      // Log for you to verify logic in DevTools F12 (Console)
      console.log(`[Push Tracker] Click #${clickCount} | Probability Roll: ${coinToss.toFixed(2)} | Trigger Popup: ${shouldTrigger}`);

      if (shouldTrigger) {
        triggerNativePrompt(e);
      }
    }, { capture: true }); // Capture true ensures we catch the click before any other framework code

  })();
</script>
