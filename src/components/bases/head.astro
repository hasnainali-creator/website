---
import { SITE } from "@/lib/config";
import type { ArticleMeta, Meta } from "@/lib/types";

type Props = {
  meta: Meta | ArticleMeta;
  preloadImage?: string | any;
  preloadSizes?: string;
};

const { meta, preloadImage, preloadSizes = "100vw" } = Astro.props;

import { categoriesHandler } from "@/lib/handlers/categories";
const catProvider = await categoriesHandler.getProvider();
const navCategories = catProvider.getNestedCategories();
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

// Zenith: High-Fidelity Universal Speed Path
import { getImage } from "astro:assets";
const isArticleMeta = (meta: any): meta is ArticleMeta => meta.type === "article";
const OGImage = new URL(meta.ogImage, Astro.url).href;

let preloadSrcset = "";


if (preloadImage) {
  if (typeof preloadImage === 'object') {
    const q = 35; // Supreme Aggressive quality for Universal Speed (< 1.0s LCP)
    const img400 = await getImage({ src: preloadImage, format: 'avif', width: 400, quality: q });
    const img665 = await getImage({ src: preloadImage, format: 'avif', width: 665, quality: q });
    const img800 = await getImage({ src: preloadImage, format: 'avif', width: 800, quality: q });
    const img1024 = await getImage({ src: preloadImage, format: 'avif', width: 1024, quality: q });
    preloadSrcset = `${img400.src} 400w, ${img665.src} 665w, ${img800.src} 800w, ${img1024.src} 1024w`;

  } else {
    preloadSrcset = `${preloadImage} 400w, ${preloadImage} 665w, ${preloadImage} 800w, ${preloadImage} 1024w`;

  }
} else if (isArticleMeta(meta)) {
  preloadSrcset = `${OGImage} 400w, ${OGImage} 665w, ${OGImage} 800w, ${OGImage} 1024w`;

}

const schemaOrg: any = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${Astro.site}#website`,
      url: Astro.site,
      name: SITE.title,
      description: SITE.description,
      publisher: {
        "@id": `${Astro.site}#organization`,
      },
    },
    {
      "@type": "NewsMediaOrganization",
      "@id": `${Astro.site}#organization`,
      name: SITE.title,
      url: Astro.site,
      logo: {
        "@type": "ImageObject",
        "@id": `${Astro.site}#logo`,
        url: new URL("favicon-96x96.png", Astro.site).href,
        contentUrl: new URL("favicon-96x96.png", Astro.site).href,
        width: 96,
        height: 96,
        caption: SITE.title,
      },
      image: {
        "@id": `${Astro.site}#logo`,
      },
      sameAs: [
        "https://instagram.com/omnysports",
        "https://twitter.com/omnysports",
        "https://facebook.com/omnysports",
        "https://tiktok.com/@omnysports",
      ],
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer service",
        url: new URL("contact", Astro.site).href,
        email: "contact@omnysports.com",
      },
    },
  ],
};

if (isArticleMeta(meta)) {
  schemaOrg["@graph"].push({
    "@type": "NewsArticle",
    "@id": `${canonicalURL}#article`,
    isPartOf: {
      "@id": `${Astro.site}#website`,
    },
    headline: meta.metaTitle || meta.title || "News Article",
    datePublished: new Date(meta.publishedTime || Date.now()).toISOString(),
    dateModified: new Date(
      meta.lastModified || meta.publishedTime || Date.now(),
    ).toISOString(),
    description: meta.description || SITE.description,
    copyrightYear: new Date(meta.publishedTime || Date.now()).getFullYear(),
    isAccessibleForFree: "True",
    articleSection: meta.category?.[0] || "Sports News",
    mainEntityOfPage: {
      "@id": canonicalURL,
    },
    image: [OGImage],
    author: (meta.authors && meta.authors.length > 0
      ? meta.authors
      : [{ name: SITE.author, link: "admin" }]
    ).map((author) => ({
      "@type": "Person",
      name: author.name,
      url: new URL(`authors/${author.link}`, Astro.site).href,
    })),
    publisher: {
      "@type": "Organization",
      name: SITE.title,
      logo: {
        "@type": "ImageObject",
        url: new URL("favicon-96x96.png", Astro.site).href,
      },
    },
    inLanguage: SITE.locale,
    about: meta.keywords
      ? meta.keywords.split(",").map((kw: string) => ({
          "@type": "Thing",
          name: kw.trim(),
        }))
      : undefined,
    speakable: {
      "@type": "SpeakableSpecification",
      cssSelector: [".article-headline", ".article-content"],
    },
  });
}

// SiteNavigationElement for rich sitelinks
schemaOrg["@graph"].push({
  "@type": "ItemList",
  "@id": `${Astro.site}#primary-navigation`,
  name: "Primary Navigation",
  itemListElement: [
    {
      "@type": "SiteNavigationElement",
      position: 1,
      name: "Home",
      url: Astro.site,
    },
    ...navCategories.map((cat, index) => ({
      "@type": "SiteNavigationElement",
      position: index + 2,
      name: cat.data.title || cat.id,
      url: new URL(`categories/${cat.id}/1`, Astro.site).href,
    })),
  ],
});

const schemaOrgString = JSON.stringify(schemaOrg);

const breadcrumbSchema: any = meta.breadcrumbs
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: Astro.site,
        },
        ...meta.breadcrumbs.map((crumb, index) => ({
          "@type": "ListItem",
          position: index + 2,
          name: crumb.label || "Page",
          item: new URL(crumb.url, Astro.site).href,
        })),
      ],
    }
  : null;

const breadcrumbSchemaString = breadcrumbSchema
  ? JSON.stringify(breadcrumbSchema)
  : null;
---

<head>
  <meta charset={SITE.charset} />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  {/* Level 0 Alpha: DNS & Preconnect Optimization */}
  <link rel="preconnect" href="https://omnysports.pages.dev" crossorigin />
  <link rel="dns-prefetch" href="https://omnysports.pages.dev" />

  {/* Priority #1 (Visual Completion): Preloading ALL Critical Above-the-Fold Fonts */}
  <link rel="preload" href="/fonts/source-serif-4-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/source-sans-pro-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

  {/* Priority #2 (LCP Monopolization): The Image LCP with fetchpriority="high" */}
  {preloadSrcset && <link rel="preload" as="image" type="image/avif" imagesrcset={preloadSrcset} imagesizes={preloadSizes} fetchpriority="high" />}

  <script is:inline>
    (function () {
      const theme = localStorage.getItem("astro-theme") || "light";
      document.documentElement.setAttribute("data-theme", theme);
    })();
  </script>
  <!-- Global Metadata -->
  <meta name="generator" content={Astro.generator} />

  <!-- Font Architecture: Rendering enforcement -->
  <style is:inline>
    @font-face {
      font-family: "Source Sans Pro";
      font-style: normal;
      font-display: swap;
      font-weight: 400;
      src: url("/fonts/source-sans-pro-latin-400-normal.woff2") format("woff2");
      size-adjust: 100%;
      ascent-override: 90%;
      descent-override: 22%;
      line-gap-override: 0%;
    }
    @font-face {
      font-family: "Source Serif 4 Variable";
      font-style: normal;
      font-display: swap;
      font-weight: 200 900;
      src: url("/fonts/source-serif-4-latin-wght-normal.woff2")
        format("woff2-variations");
      size-adjust: 100%;
      ascent-override: 90%;
      descent-override: 22%;
      line-gap-override: 0%;
    }
    @font-face {
      font-family: "Inter";
      font-style: normal;
      font-display: swap;
      font-weight: 100 900;
      src: url("/fonts/inter-latin-wght-normal.woff2")
        format("woff2-variations");
      size-adjust: 107%;
      ascent-override: 90%;
      descent-override: 22%;
      line-gap-override: 0%;
    }
  </style>


  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Page Metadata -->
  <title>{meta.title}</title>
  <meta name="title" content={meta.metaTitle} />
  <meta name="description" content={meta.description} />
  {meta.keywords && <meta name="keywords" content={meta.keywords} />}

  <!-- Essential SEO Robots for Google News -->
  <!-- TOTAL SEO SHIELDING: Purging Dummy Content from Google -->
  {
    SITE.SHIELD_MODE ? (
      <meta name="robots" content="noindex, nofollow, noarchive" />
    ) : (
      <meta name="robots" content="index, follow" />
    )
  }

  <!-- Favicons -->
  <!-- 1. Modern Dynamic SVG (Theme-Aware Tab & Search) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=21" sizes="any" />

  <!-- 2. Theme-Specific Explicit Overrides (For 100% Reliability) -->
  <link
    rel="icon"
    type="image/svg+xml"
    media="(prefers-color-scheme: light)"
    href="/favicon-light.svg?v=21"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    media="(prefers-color-scheme: dark)"
    href="/favicon-dark.svg?v=21"
  />

  <!-- 3. Professional PNG Fallback (High-Res for Google Search results) -->
  <link
    rel="icon"
    type="image/png"
    sizes="96x96"
    href="/favicon-96x96.png?v=21"
  />
  <link
    rel="apple-touch-icon"
    sizes="180x180"
    href="/apple-touch-icon.png?v=21"
  />
  <meta name="apple-mobile-web-app-title" content={SITE.title} />
  <meta name="application-name" content={SITE.title} />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- RSS & Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link
    rel="alternate"
    type="application/rss+xml"
    title={SITE.title}
    href={new URL("rss.xml", Astro.site)}
  />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={meta.type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={meta.metaTitle} />
  <meta property="og:description" content={meta.description} />
  <meta property="og:image" content={OGImage} />
  <meta property="og:image:alt" content={meta.ogImageAlt} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={SITE.title} />
  <meta property="og:locale" content={SITE.locale} />

  <!-- Twitter -->
  <meta property="twitter:site" content="@OmnySports" />
  <meta property="twitter:creator" content="@OmnySports" />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={meta.metaTitle} />
  <meta property="twitter:description" content={meta.description} />
  <meta property="twitter:image" content={OGImage} />
  <meta property="twitter:image:alt" content={meta.ogImageAlt} />

  {
    isArticleMeta(meta) ? (
      <>
        <meta
          property="article:published_time"
          content={new Date(meta.publishedTime).toISOString()}
        />
        <meta
          property="article:modified_time"
          content={new Date(meta.lastModified).toISOString()}
        />
        {(meta as any).category?.[0] && (
          <meta
            property="article:section"
            content={(meta as any).category[0]}
          />
        )}
        {meta.keywords &&
          meta.keywords
            .split(",")
            .map((tag) => <meta property="article:tag" content={tag.trim()} />)}

        {meta.authors.map((author) => (
          <>
            <meta property="author" content={author.name} />
            <meta
              property="article:author"
              content={`${Astro.site}authors/${author.link}`}
            />
          </>
        ))}
      </>
    ) : null
  }

  {/* Technical SEO: Pagination Relations */}
  {meta.prev && <link rel="prev" href={new URL(meta.prev, Astro.site).href} />}
  {meta.next && <link rel="next" href={new URL(meta.next, Astro.site).href} />}

  <script is:inline type="application/ld+json" set:html={schemaOrgString} />
  {
    breadcrumbSchemaString && (
      <script
        is:inline
        type="application/ld+json"
        set:html={breadcrumbSchemaString}
      />
    )
  }

  {/* Speculation Rules API: 'Hard Intelligence' Zero-Latency Pre-rendering */}
  {
    /* This pre-renders internal links during hover/intent for 0ms transitions */
  }
  <script type="speculationrules" is:inline>
    {
      "prerender": [
        {
          "where": {
            "and": [
              { "href_matches": "/*" },
              { "not": { "href_matches": ["/admin/*", "/keystatic/*"] } },
              { "not": { "selector_matches": "[rel~=nofollow]" } }
            ]
          },
          "eagerness": "moderate"
        }
      ]
    }
  </script>

  <!-- Speculation Rules: Predictive Loading -->
</head>
